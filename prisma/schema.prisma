// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  watchlist    Movie[]  @relation("UserWatchlist")
  ratings      Rating[]

  @@map("users")
}

model Movie {
  id           Int     @id @default(autoincrement())
  tmdbId       Int     @unique
  title        String
  overview     String  @db.Text
  releaseDate  String? // "YYYY-MM-DD"
  posterPath   String?
  backdropPath String?
  popularity   Float
  voteAverage  Float
  voteCount    Int
  adult        Boolean @default(false)
  language     String? // original_language

  // New local rating fields
  localVoteAverage Float @default(0)
  localVoteCount   Int   @default(0)

  // totalVoteAverage = (voteAverage * voteCount + localVoteAverage * localVoteCount) / (voteCount + localVoteCount)
  totalVoteAverage Float @default(0)
  totalVoteCount   Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  genres        Genre[]
  watchlistedBy User[]   @relation("UserWatchlist")
  ratings       Rating[]

  @@index([totalVoteAverage])
  @@index([popularity])

  @@map("movies")
}

model Genre {
  id     Int     @id @default(autoincrement())
  tmdbId Int     @unique
  name   String
  movies Movie[]

  @@map("genres")
}

model Rating {
  id        Int      @id @default(autoincrement())
  value     Int // 1 to 10
  userId    Int
  movieId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  movie     Movie    @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])

  @@map("ratings")
}
